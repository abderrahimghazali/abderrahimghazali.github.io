---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout
  title="Blog | Abderrahim GHAZALI"
  description="Articles on AI, automation, Drupal, and software engineering."
  keywords="blog, AI, automation, Drupal, software engineering"
  url="https://abderrahimghazali.github.io/blog"
>
  <Nav />

  <h1 class="text-xl font-semibold text-[#111] mb-10">Blog</h1>

  {posts.length === 0 && (
    <p class="text-[15px] text-[#555]">No posts yet. Check back soon.</p>
  )}

  <div class="space-y-8">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="block group">
        <article>
          <time class="text-xs text-[#999]" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <h2 class="text-[15px] font-medium text-[#222] mt-1 group-hover:text-[#111] transition-colors">
            {post.data.title}
          </h2>
          <p class="text-[14px] text-[#666] mt-1 leading-relaxed">
            {post.data.description}
          </p>
        </article>
      </a>
    ))}
  </div>
</Layout>
