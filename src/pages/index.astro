---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const caseStudies = [
  {
    title: "Agent orchestration for a healthcare operations platform",
    kicker: "Healthcare",
    year: "2025",
    desc: "Built a multi-agent system that triages inbound clinical documents, extracts structured data, and routes cases through a review pipeline — replacing a manual queue that was choking a 120-person ops team.",
    stack: ["LangChain", "Python", "Postgres", "pgvector", "n8n", "AWS"],
    stats: [
      { v: "82%", l: "Manual steps removed" },
      { v: "4.2s", l: "Avg document turnaround" },
    ],
    body: [
      "Led the architecture end-to-end: agent graph design, tool contracts, retrieval layer, audit trails. Replaced a spreadsheet-driven review queue with a deterministic state machine that agents operate inside of.",
      "The hardest part wasn't the LLM calls — it was making the system legible to non-technical reviewers. Every agent action is traceable, reversible, and tied back to the source document."
    ]
  },
  {
    title: "Drupal migration & performance overhaul for a national publisher",
    kicker: "Publishing",
    year: "2024",
    desc: "Migrated a decade of editorial content from a legacy CMS into a custom Drupal architecture. Tuned caching, media pipelines, and search for sub-second response at 500K+ monthly readers.",
    stack: ["Drupal 10", "PHP", "Redis", "Varnish", "Elasticsearch", "Terraform"],
    stats: [
      { v: "500K+", l: "Monthly active readers" },
      { v: "<400ms", l: "P95 page render" },
    ],
    body: [
      "Wrote custom migration plugins to normalize 14 content types across three source databases. Editorial could keep publishing in the legacy system until cutover; diffs were reconciled continuously.",
      "Post-launch: custom render cache strategy, image derivatives moved to a CDN pipeline, and search reindexed to Elasticsearch with editor-tunable boosts."
    ]
  },
  {
    title: "Workflow automation for a government digital service",
    kicker: "Public sector",
    year: "2024",
    desc: "Designed and shipped n8n-backed workflows that eliminated roughly 80% of manual back-office work for a citizen-facing service, with audit-ready paper trails.",
    stack: ["n8n", "Node.js", "Symfony", "Postgres", "Docker"],
    stats: [
      { v: "14", l: "Integrated systems" },
      { v: "2.1M", l: "Records processed / yr" },
    ],
    body: [
      "The brief looked simple — \"automate the forms handling\" — and turned into a full integration project: legacy SOAP endpoints, a GDS design-system front end, and a review board that needed human checkpoints at specific stages.",
      "Shipped as a small set of composable workflows rather than one monolithic pipeline. Each has its own SLA, failure routing, and ownership."
    ]
  },
  {
    title: "Semantic search & RAG for an e-commerce knowledge base",
    kicker: "E-commerce",
    year: "2023",
    desc: "Replaced a keyword search that was failing support agents with a hybrid semantic + lexical retriever, grounded in a product catalogue of ~40K SKUs and years of ticket history.",
    stack: ["OpenAI", "pgvector", "Python", "FastAPI", "Next.js"],
    stats: [
      { v: "40K", l: "SKUs indexed" },
      { v: "220ms", l: "Median query latency" },
    ],
    body: [
      "Started with evals: built a labelled set from real tickets before writing a line of retrieval code. That dataset is what told us when the hybrid scoring was actually winning and when it was just drifting.",
      "Deployed behind a thin internal UI that agents already knew. No training needed — the old search box just got better."
    ]
  }
];

const projects = [
  {
    name: "MRRTracker",
    badge: "#4 on Product Hunt",
    desc: "macOS menubar app that tracks Monthly Recurring Revenue in real time across Stripe, Paddle, and Lemon Squeezy. Built solo, launched to #4 of the day.",
    stack: ["Swift", "macOS", "SaaS"],
    link: "https://www.producthunt.com/products/mrrtracker",
  },
  {
    name: "MailFleet",
    badge: "Open source",
    desc: "Desktop email campaign manager built with Tauri, React, and Rust. Sends through AWS SES with real-time tracking, contact dedup, and GDPR-compliant unsubscribe flows.",
    stack: ["Rust", "Tauri", "React", "AWS SES"],
    link: "https://mailfleet.vercel.app/",
  }
];

const stack = [
  { cat: "AI / Agents", items: ["LangChain", "LangGraph", "OpenAI", "Anthropic", "pgvector", "LlamaIndex", "Ollama", "n8n"] },
  { cat: "Languages", items: ["PHP", "TypeScript", "Python", "Rust", "Swift", "Go", "SQL", "Bash"] },
  { cat: "Frameworks", items: ["Drupal", "Symfony", "Laravel", "React", "Next.js", "Node.js", "FastAPI", "Tauri"] },
  { cat: "Infra", items: ["Docker", "AWS", "Postgres", "Redis", "Varnish", "Elasticsearch", "Terraform", "GitHub Actions"] },
];

const repos = [
  { org: "abderrahimghazali", name: "mailfleet", desc: "Desktop email campaign manager — Tauri + Rust + React, AWS SES under the hood.", lang: "Rust" },
  { org: "abderrahimghazali", name: "drupal-agent-toolkit", desc: "A small toolkit for wiring LLM agents into Drupal entity workflows.", lang: "PHP" },
  { org: "abderrahimghazali", name: "n8n-eval-nodes", desc: "Custom n8n nodes for running LLM evals inline with your automation graph.", lang: "TypeScript" },
  { org: "abderrahimghazali", name: "pgvector-recipes", desc: "Pragmatic pgvector patterns for production RAG — schema, indexes, hybrid scoring.", lang: "SQL" }
];
---

<Layout
  title="Abderrahim Ghazali — Software Engineer"
  description="Software engineer since 2014. AI agent systems, workflow automation, Drupal architecture, and full-stack development."
  keywords="AI agent development, RAG pipelines, n8n automation, Drupal expert, full-stack developer"
  url="https://abderrahimghazali.github.io/"
>
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-main reveal-on-scroll">
        <div class="hero-left">
          <p class="hero-name">Abderrahim Ghazali</p>
          <h1 class="hero-title">
            Software engineer since 2014. I build automation systems,
            AI tooling, and web platforms — mostly for teams
            where things breaking at 2am is not an option.
          </h1>

          <p class="hero-sub">
            Based in Paris. Open to consulting and contract work.
          </p>
        </div>

        <div class="hero-side">
          <div class="hero-portrait">
            <img src="/me.jpeg" alt="Abderrahim Ghazali" width="400" height="500" loading="eager" />
          </div>
        </div>
      </div>

      <div class="cta-row reveal-on-scroll">
        <a class="btn primary" href="https://cal.com/abderrahimghazali/15min?overlayCalendar=true" target="_blank" rel="noopener noreferrer">
          Book a call <span class="arrow">→</span>
        </a>
        <a class="btn" href="mailto:ghazali.abderrahim1@gmail.com">
          Email <span class="arrow">→</span>
        </a>
        <a class="btn" href="#work">
          See work <span class="arrow">↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work">
    <div class="container">
      <div class="section-head reveal-on-scroll">
        <div>
          <h2>Selected work</h2>
        </div>
        <p class="sub">Recent engagements. Click a row to expand.</p>
      </div>

      <div class="work-list reveal-on-scroll">
        {caseStudies.map((cs, i) => (
          <div class="case" data-case={i}>
            <div class="case-top">
              <span class="case-kicker">{cs.kicker} · {cs.year}</span>
              <span class="toggle"><span>+</span></span>
            </div>
            <div class="case-title">{cs.title}</div>
            <div class="case-desc">{cs.desc}</div>

            <div class="case-detail">
              <div class="case-detail-inner">
                <div class="case-detail-stats">
                  {cs.stats.map((s) => (
                    <div class="stat">
                      <div class="v">{s.v}</div>
                      <div class="l">{s.l}</div>
                    </div>
                  ))}
                </div>
                <div class="case-detail-body">
                  {cs.body.map((para) => <p>{para}</p>)}
                  <div class="tags">
                    {cs.stack.map(s => <span class="tag">{s}</span>)}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="container">
      <div class="section-head reveal-on-scroll">
        <div>
          <h2>Side projects</h2>
        </div>
        <p class="sub">Things I built on my own time that turned into products.</p>
      </div>

      <div class="projects reveal-on-scroll">
        {projects.map((pr) => (
          <a class="proj" href={pr.link} target="_blank" rel="noopener noreferrer">
            <div class="proj-head">
              <h3>{pr.name}</h3>
              <div class="proj-badge">{pr.badge}</div>
            </div>
            <p>{pr.desc}</p>
            <div class="proj-foot">
              <div class="tags">
                {pr.stack.map(s => <span class="tag">{s}</span>)}
              </div>
              <span class="proj-link">View →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section id="stack">
    <div class="container">
      <div class="section-head reveal-on-scroll">
        <div>
          <h2>Stack</h2>
        </div>
        <p class="sub">What I actually use. Not a wishlist.</p>
      </div>

      <div class="stack-list reveal-on-scroll">
        {stack.map((group) => (
          <div class="stack-row">
            <h4>{group.cat}</h4>
            <div class="stack-items">
              {group.items.map((item) => (
                <span class="stack-item">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section id="oss">
    <div class="container">
      <div class="section-head reveal-on-scroll">
        <div>
          <h2>Open source</h2>
        </div>
        <p class="sub">Contrib modules, plugins, and tools across a few ecosystems.</p>
      </div>

      <div class="repo-list reveal-on-scroll">
        {repos.map((r) => (
          <div class="repo">
            <div>
              <div class="repo-name"><span class="slash">{r.org} /</span> {r.name}</div>
              <div class="repo-desc">{r.desc}</div>
            </div>
            <div class="repo-lang">
              <span class="lang-dot"></span>
              {r.lang}
            </div>
          </div>
        ))}
        <div class="oss-links">
          <a href="https://github.com/abderrahimghazali" target="_blank" rel="noopener noreferrer" class="btn"><img src="/icons/github.svg" alt="" width="16" height="16" class="btn-icon" /> GitHub <span class="arrow">→</span></a>
          <a href="https://addons.sylius.com/en_US/vendors/abderrahim-ghazali" target="_blank" rel="noopener noreferrer" class="btn"><img src="/icons/sylius.png" alt="" width="16" height="16" class="btn-icon" /> Sylius Store <span class="arrow">→</span></a>
          <a href="https://www.drupal.org/u/gabderrahim" target="_blank" rel="noopener noreferrer" class="btn"><img src="/icons/drupal.svg" alt="" width="16" height="16" class="btn-icon" /> Drupal.org <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <div class="section-head reveal-on-scroll">
        <div>
          <h2>Get in touch</h2>
        </div>
        <p class="sub">I reply to most emails within a day.</p>
      </div>

      <div class="contact-links reveal-on-scroll">
        <a href="https://cal.com/abderrahimghazali/15min?overlayCalendar=true" target="_blank" rel="noopener noreferrer" class="contact-row">
          <span class="lbl">Book a call</span>
          <span>cal.com/abderrahimghazali <span class="arr">↗</span></span>
        </a>
        <a href="mailto:ghazali.abderrahim1@gmail.com" class="contact-row">
          <span class="lbl">Email</span>
          <span>ghazali.abderrahim1@gmail.com <span class="arr">↗</span></span>
        </a>
        <a href="https://github.com/abderrahimghazali" target="_blank" rel="noopener noreferrer" class="contact-row">
          <span class="lbl">GitHub</span>
          <span>github.com/abderrahimghazali <span class="arr">↗</span></span>
        </a>
        <a href="https://www.linkedin.com/in/abderrahimghazali/" target="_blank" rel="noopener noreferrer" class="contact-row">
          <span class="lbl">LinkedIn</span>
          <span>linkedin.com/in/abderrahimghazali <span class="arr">↗</span></span>
        </a>
        <a href="https://www.drupal.org/u/gabderrahim" target="_blank" rel="noopener noreferrer" class="contact-row">
          <span class="lbl">Drupal.org</span>
          <span>drupal.org/u/gabderrahim <span class="arr">↗</span></span>
        </a>
      </div>

      <footer>
        <span>© 2026 Abderrahim Ghazali</span>
      </footer>
    </div>
  </section>
</Layout>

<script>
  // Case study accordion
  document.querySelectorAll('.case').forEach((el) => {
    el.addEventListener('click', () => {
      const isOpen = el.classList.contains('open');
      document.querySelectorAll('.case').forEach(c => c.classList.remove('open'));
      if (!isOpen) el.classList.add('open');
    });
  });

  // Open first case by default
  const firstCase = document.querySelector('.case');
  if (firstCase) firstCase.classList.add('open');

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal-on-scroll');
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(el => observer.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('visible'));
  }
</script>
