// Generate contribution grid deterministically
function genContribs() {
  const cells: number[] = [];
  const seed = (i: number) => Math.sin(i * 127.1 + 0.5) * 43758.5453;
  for (let w = 0; w < 52; w++) {
    for (let d = 0; d < 7; d++) {
      const r = Math.abs(seed(w * 7 + d)) % 1;
      let lvl = 0;
      if (r > 0.55) lvl = 1;
      if (r > 0.72) lvl = 2;
      if (r > 0.86) lvl = 3;
      if (r > 0.94) lvl = 4;
      if (d === 6 || d === 0) lvl = Math.max(0, lvl - 1);
      cells.push(lvl);
    }
  }
  // Column-major arrangement
  const grid: number[] = [];
  for (let d = 0; d < 7; d++) {
    for (let w = 0; w < 52; w++) {
      grid.push(cells[w * 7 + d]);
    }
  }
  return grid;
}

const contribGrid = genContribs();
