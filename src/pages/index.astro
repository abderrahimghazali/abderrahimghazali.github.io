---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="Abderrahim GHAZALI | AI Agent Developer & Drupal Expert"
  description="Software engineer with 11+ years of experience. AI agent development, RAG pipelines, semantic search, n8n workflow automation, and enterprise Drupal architecture."
  keywords="AI agent development, RAG pipelines, semantic search, n8n automation, Drupal expert, LangChain developer, workflow automation, full-stack developer"
  url="https://abderrahimghazali.github.io/"
>
  <Nav />

  <!-- Hero -->
  <div class="fade-in flex items-start gap-5 mb-12" style="--stagger: 2">
    <img
      src="/me.jpeg"
      alt="Abderrahim GHAZALI"
      class="w-16 h-16 rounded-full object-cover shrink-0 grayscale"
      width="64"
      height="64"
      loading="eager"
    />
    <div>
      <h1 class="text-xl font-semibold text-[#111] mb-1">Abderrahim GHAZALI</h1>
      <p class="text-sm text-[#666]">Software Engineer / Automation, AI, Drupal</p>
    </div>
  </div>

  <!-- Intro -->
  <section class="fade-in mb-12" style="--stagger: 3">
    <p class="text-[15px] leading-relaxed text-[#555]">
      I specialize in designing and shipping production-grade automation systems, AI-driven tooling, and enterprise web platforms. Over 11 years of delivering software across healthcare, publishing, government, and e-commerce. Reliability, performance, and long-term maintainability are non-negotiable.
    </p>
  </section>

  <!-- What I Do -->
  <section class="fade-in mb-12" style="--stagger: 4">
    <h2 class="text-sm font-medium text-[#111] uppercase tracking-wider mb-5">Areas of Expertise</h2>
    <div class="space-y-4">
      <div class="group">
        <h3 class="text-[15px] font-medium text-[#222] mb-1">AI & Automation Engineering</h3>
        <p class="text-[15px] leading-relaxed text-[#555]">
          Architecting autonomous agent systems, RAG pipelines, and semantic search solutions using LangChain, custom orchestration layers, and LLM integration. Building custom n8n workflows for end-to-end process automation. Reduced manual workflows by 80%+ in production environments.
        </p>
      </div>
      <div class="border-t border-[#eee]"></div>
      <div class="group">
        <h3 class="text-[15px] font-medium text-[#222] mb-1">Drupal Architecture</h3>
        <p class="text-[15px] leading-relaxed text-[#555]">
          Deep expertise since 2014. Custom module development, complex migration strategies, performance tuning at scale. Delivered platforms handling 500K+ monthly users with sub-second response times.
        </p>
      </div>
      <div class="border-t border-[#eee]"></div>
      <div class="group">
        <h3 class="text-[15px] font-medium text-[#222] mb-1">Full-Stack & DevOps</h3>
        <p class="text-[15px] leading-relaxed text-[#555]">
          End-to-end ownership across React, Next.js, Node.js, Symfony, and Laravel. Infrastructure design with Docker, CI/CD pipelines, and cloud deployment. I ship the full lifecycle, from architecture through monitoring.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="fade-in mb-12" style="--stagger: 5">
    <h2 class="text-sm font-medium text-[#111] uppercase tracking-wider mb-5">Projects</h2>
    <div class="space-y-6">
      <a href="https://www.producthunt.com/products/mrrtracker" target="_blank" rel="noopener noreferrer" class="project-card block">
        <div class="flex items-start gap-4">
          <img src="/mrrtracker-icon.png" alt="MRRTracker app icon" class="w-12 h-12 rounded-xl shrink-0" width="48" height="48" loading="lazy" />
          <div class="flex-1">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-[15px] font-medium text-[#222]">MRRTracker</h3>
              <span class="shrink-0 text-xs text-[#C15F3C] font-medium bg-[#C15F3C]/10 px-2 py-1 rounded">#4 on Product Hunt</span>
            </div>
            <p class="text-[14px] text-[#666] mt-1 leading-relaxed">macOS menubar app that tracks your Monthly Recurring Revenue in real time. Supports Stripe, Paddle, and Lemon Squeezy.</p>
            <div class="flex gap-2 mt-3">
              <span class="tag">Swift</span>
              <span class="tag">macOS</span>
              <span class="tag">SaaS</span>
            </div>
          </div>
        </div>
      </a>
      <div class="border-t border-[#eee]"></div>
      <a href="https://github.com/abderrahimghazali/mailfleet" target="_blank" rel="noopener noreferrer" class="project-card block">
        <div class="flex items-start gap-4">
          <img src="/mailfleet-icon.png" alt="MailFleet app icon" class="w-12 h-12 rounded-xl shrink-0" width="48" height="48" loading="lazy" />
          <div class="flex-1">
            <h3 class="text-[15px] font-medium text-[#222]">MailFleet</h3>
            <p class="text-[14px] text-[#666] mt-1 leading-relaxed">Desktop email campaign manager built with Tauri, React, and Rust. Sends through AWS SES with real-time tracking, contact dedup, and GDPR-compliant unsubscribe.</p>
            <div class="flex gap-2 mt-3">
              <span class="tag">Rust</span>
              <span class="tag">Tauri</span>
              <span class="tag">React</span>
              <span class="tag">AWS SES</span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Connect -->
  <section class="fade-in" style="--stagger: 6">
    <h2 class="text-sm font-medium text-[#111] uppercase tracking-wider mb-5">Contact</h2>
    <p class="text-[15px] leading-relaxed text-[#555] mb-6">
      Available for consulting, contract work, and technical partnerships.
    </p>
    <div class="flex flex-wrap gap-4 text-sm">
      <a href="https://cal.com/abderrahimghazali/15min?overlayCalendar=true" target="_blank" rel="noopener noreferrer" class="link-pill">Book a call</a>
      <a href="mailto:ghazali.abderrahim1@gmail.com" class="link-pill">Email</a>
      <a href="https://github.com/abderrahimghazali" target="_blank" rel="noopener noreferrer" class="link-pill">GitHub</a>
      <a href="https://www.linkedin.com/in/abderrahimghazali/" target="_blank" rel="noopener noreferrer" class="link-pill">LinkedIn</a>
      <a href="https://www.drupal.org/u/gabderrahim" target="_blank" rel="noopener noreferrer" class="link-pill">Drupal.org</a>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;
    document.querySelectorAll('.fade-in').forEach(el => {
      el.style.opacity = '0';
      el.classList.add('is-visible');
    });
  });
</script>

<style>
  .project-card {
    padding: 12px 14px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }
  .project-card:hover {
    background-color: #f2f2f2;
  }

  .tag {
    display: inline-block;
    font-size: 11px;
    color: #888;
    background: #f0f0f0;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    color: #555;
    font-size: 13px;
    transition: all 0.2s ease;
  }
  .link-pill:hover {
    border-color: #111;
    color: #111;
  }

  /* Fade-in: visible by default, animated via JS */
  .fade-in.is-visible {
    animation: fadeIn 0.5s ease forwards;
    animation-delay: calc(var(--stagger) * 0.1s);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
