---
import Layout from '../layouts/Layout.astro';
import StructuredDataAbout from '../components/StructuredDataAbout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="About | Abderrahim GHAZALI"
  description="11+ years in software engineering. AI agent development, RAG systems, semantic search, n8n workflow automation, enterprise Drupal architecture, and full-stack development."
  keywords="AI agent development, RAG systems, semantic search, n8n automation, Drupal architecture, LangChain, full-stack developer, workflow automation"
  url="https://abderrahimghazali.github.io/about"
>
  <Nav />

  <!-- Header -->
  <header class="fade-in mb-12" style="--stagger: 2">
    <h1 class="text-2xl font-semibold text-[#111] mb-2">About</h1>
  </header>

  <!-- Content -->
  <article class="space-y-10">
    <section class="fade-in" style="--stagger: 3">
      <p class="body-text mb-4">
        I'm Abderrahim, a software engineer based in Paris. I've been writing code professionally since 2014 — starting with Drupal and PHP, then expanding into React, Node.js, and eventually AI and automation.
      </p>
      <p class="body-text">
        These days I split my time between building products of my own and consulting for companies that need help with complex systems. I like working across the full stack, but what I enjoy most is taking a messy manual process and turning it into something that runs on its own.
      </p>
    </section>

    <section class="fade-in" style="--stagger: 4">
      <h2 class="section-heading">What I've been up to</h2>
      <p class="body-text mb-4">
        I launched <a href="https://www.mrrtracker.app" target="_blank" rel="noopener noreferrer" class="inline-link">MRRTracker</a>, a macOS menubar app for tracking recurring revenue — it hit #4 on Product Hunt. I built <a href="https://github.com/abderrahimghazali/mailfleet" target="_blank" rel="noopener noreferrer" class="inline-link">MailFleet</a>, a desktop email campaign tool using Tauri and Rust. I've shipped Sylius e-commerce plugins, iOS apps, CLI tools, and a Claude Code plugin for Drupal development.
      </p>
      <p class="body-text">
        On the consulting side, I've delivered platforms handling 500K+ monthly users, built RAG pipelines and semantic search systems, and designed n8n automation workflows that cut manual work by 80%+ for clients in healthcare, publishing, and government.
      </p>
    </section>

    <section class="fade-in" style="--stagger: 5">
      <h2 class="section-heading">How I work</h2>
      <p class="body-text">
        I care about shipping things that last. I'd rather spend an extra day on error handling and edge cases than rush something out and fix it in production. I'm comfortable working solo or leading a small team, and I prefer direct communication over process overhead.
      </p>
    </section>

    <section class="fade-in" style="--stagger: 6">
      <h2 class="section-heading">Stack</h2>
      <p class="body-text">
        TypeScript, React, Next.js, Node.js, Rust, Swift, Python, PHP, Drupal, Symfony, Laravel, PostgreSQL, Docker, AWS, n8n, LangChain. I pick whatever fits the problem.
      </p>
    </section>

    <!-- Contact -->
    <section class="fade-in pt-6 border-t border-[#eee]" style="--stagger: 7">
      <p class="body-text mb-6">
        Open to consulting, contract work, and interesting collaborations.
      </p>
      <div class="flex flex-wrap gap-4 text-sm">
        <a href="https://cal.com/abderrahimghazali/15min?overlayCalendar=true" target="_blank" rel="noopener noreferrer" class="link-pill">Book a call</a>
        <a href="mailto:ghazali.abderrahim1@gmail.com" class="link-pill">Email</a>
        <a href="https://github.com/abderrahimghazali" target="_blank" rel="noopener noreferrer" class="link-pill">GitHub</a>
        <a href="https://www.linkedin.com/in/abderrahim-ghazali-5121b855" target="_blank" rel="noopener noreferrer" class="link-pill">LinkedIn</a>
        <a href="https://www.drupal.org/u/gabderrahim" target="_blank" rel="noopener noreferrer" class="link-pill">Drupal.org</a>
      </div>
    </section>
  </article>

  <StructuredDataAbout />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;
    document.querySelectorAll('.fade-in').forEach(el => {
      el.style.opacity = '0';
      el.classList.add('is-visible');
    });
  });
</script>

<style>
  .section-heading {
    font-size: 14px;
    font-weight: 500;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  .body-text {
    font-size: 15px;
    line-height: 1.7;
    color: #555;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    color: #555;
    font-size: 13px;
    transition: all 0.2s ease;
  }
  .link-pill:hover {
    border-color: #111;
    color: #111;
  }

  .inline-link {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .inline-link:hover {
    color: #000;
  }

  /* Fade-in: visible by default, animated via JS */
  .fade-in.is-visible {
    animation: fadeIn 0.5s ease forwards;
    animation-delay: calc(var(--stagger) * 0.1s);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
