---
export interface Props {
  title: string;
  description: string;
  keywords?: string;
  url: string;
  image?: string;
  imageAlt?: string;
  type?: string;
}

const { title, description, keywords, url, image, imageAlt, type = 'website' } = Astro.props;
const siteUrl = 'https://abderrahimghazali.github.io';
const imageUrl = image ? `${siteUrl}${image}` : `${siteUrl}/me.jpeg`;
const ogImageAlt = imageAlt || 'Abderrahim GHAZALI';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- SEO Meta Tags -->
    <meta name="description" content={description}>
    {keywords && <meta name="keywords" content={keywords}>}
    <meta name="author" content="Abderrahim GHAZALI">
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
    <meta name="google-site-verification" content="0569ea929d78514b" />

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content={type}>
    <meta property="og:image" content={imageUrl}>
    <meta property="og:image:alt" content={ogImageAlt}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content={url}>
    <meta property="og:site_name" content="Abderrahim GHAZALI">
    <meta property="og:locale" content="en_US">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={imageUrl}>
    <meta name="twitter:image:alt" content={ogImageAlt}>

    <meta name="theme-color" content="#fafafa">
    <link rel="canonical" href={url}>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"></noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    <link rel="manifest" href="/manifest.json">

    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[#111] focus:text-white focus:rounded">Skip to main content</a>
    <main id="main-content" class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <slot />
    </main>

    <footer class="max-w-2xl mx-auto px-6 pb-12 text-center text-xs text-[#999]">
      <p>&copy; {new Date().getFullYear()} Abderrahim GHAZALI</p>
    </footer>

    <!-- WebSite schema: helps Google generate sitelinks -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Abderrahim GHAZALI",
        "alternateName": "Abderrahim Ghazali Portfolio",
        "url": "https://abderrahimghazali.github.io/",
        "description": "Software engineer specializing in AI automation, RAG systems, Drupal architecture, and full-stack development.",
        "author": {
          "@type": "Person",
          "name": "Abderrahim GHAZALI"
        }
      }
    </script>

    <!-- SiteNavigationElement: tells Google about page structure for sitelinks -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "SiteNavigationElement",
            "name": "Home",
            "url": "https://abderrahimghazali.github.io/"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "About",
            "url": "https://abderrahimghazali.github.io/about/"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Blog",
            "url": "https://abderrahimghazali.github.io/blog/"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "GitHub",
            "url": "https://github.com/abderrahimghazali"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "LinkedIn",
            "url": "https://www.linkedin.com/in/abderrahimghazali/"
          }
        ]
      }
    </script>

    <!-- Person schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Abderrahim GHAZALI",
        "jobTitle": "Software Engineer",
        "description": "Software engineer specializing in AI agent development, RAG pipelines, semantic search, n8n workflow automation, and enterprise Drupal architecture.",
        "url": "https://abderrahimghazali.github.io/",
        "email": "ghazali.abderrahim1@gmail.com",
        "image": "https://abderrahimghazali.github.io/me.jpeg",
        "sameAs": [
          "https://github.com/abderrahimghazali",
          "https://www.linkedin.com/in/abderrahimghazali/",
          "https://www.drupal.org/u/gabderrahim"
        ],
        "knowsAbout": [
          "AI Agent Development",
          "Retrieval-Augmented Generation (RAG)",
          "Semantic Search",
          "LangChain",
          "n8n Workflow Automation",
          "Drupal Development",
          "React",
          "Next.js",
          "Node.js",
          "DevOps",
          "Full-stack Development"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "consulting",
          "url": "https://cal.com/abderrahimghazali/15min?overlayCalendar=true",
          "email": "ghazali.abderrahim1@gmail.com",
          "availableLanguage": ["English", "French"]
        },
        "potentialAction": {
          "@type": "ReserveAction",
          "name": "Book a 15-minute call",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://cal.com/abderrahimghazali/15min?overlayCalendar=true",
            "actionPlatform": "https://schema.org/DesktopWebPlatform"
          }
        },
        "offers": [
          {
            "@type": "Service",
            "name": "AI Agent Development",
            "description": "Custom AI agent development, RAG pipelines, and semantic search solutions for business process automation"
          },
          {
            "@type": "Service",
            "name": "Workflow Automation",
            "description": "End-to-end workflow automation using custom n8n pipelines and LangChain orchestration"
          },
          {
            "@type": "Service",
            "name": "Drupal Architecture",
            "description": "Enterprise Drupal development, custom module creation, and performance optimization at scale"
          },
          {
            "@type": "Service",
            "name": "Full-Stack Development",
            "description": "Production-grade web applications with React, Next.js, Node.js, and cloud infrastructure"
          }
        ]
      }
    </script>
  </body>
</html>
